{
  // Some typical compiler options
  "compilerOptions": {
    "target": "esnext", // Preserve the latest ECMAScript syntax; ideal for modern bundlers
    "lib": ["ESNext", "DOM"], // Include the latest JavaScript APIs and browser DOM types
    "types": ["node", "webpack-env"],
    "paths": {
      "@fonts/*": ["./src/assets/fonts/*"],
      "@images/*": ["./src/assets/images/*"],
      "@scripts/*": ["./src/assets/scripts/*"],
      "@styles/*": ["./src/assets/styles/*"],
      "@components/*": ["./src/components/*"],
      "@super-assets/*": ["../../assets/*"]
},
    "outDir": "./dist/",
    "sourceMap": true, // Output inline source maps to compiled JavaScript files
    "noImplicitAny": false, // Allow the 'any' type
    "module": "esnext",
    "moduleResolution": "bundler", // Support modern module resolution for bundlers
    "jsx": "react-jsx",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },

  // NEW: Options for file/directory watching
  "watchOptions": {
    // Use native file system events for files and directories
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",

    /* Poll files for updates more frequently
    when they're updated a lot. */
    "fallbackPolling": "dynamicPriority",

    // Don't coalesce watch notification
    "synchronousWatchDirectory": true,

    /* Finally, two additional settings for reducing the amount of possible
    files to track work from these directories */
    "excludeDirectories": ["**/node_modules", "_build"],
    "excludeFiles": ["build/fileWhichChangesOften.ts"]
  }
}